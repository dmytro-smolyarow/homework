# Supabase Postgres — transaction pooler (runtime queries; port 6543, pgbouncer)
DATABASE_URL=

# Supabase Postgres — session pooler / direct connection (migrations; port 5432)
DIRECT_URL=

# Better Auth — 32+ char random secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# Base URL of the app (used by Better Auth, server side)
BETTER_AUTH_URL=http://localhost:3000

# Base URL exposed to the browser (used by the Better Auth client)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# GitHub OAuth (optional) — set both to show & enable the "Continue with GitHub" button.
# Create an OAuth App: https://github.com/settings/developers
#   Homepage URL:              http://localhost:3000
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
# Client id is public (goes in the redirect URL); only the secret must stay private.
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
